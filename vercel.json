{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/detective", "dest": "/api/detective.js" },
    { "src": "/api/lie-whisperer", "dest": "/api/lie-whisperer.js" },
    { "src": "/api/subscribe", "dest": "/api/subscribe.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/user", "dest": "/api/user.js" },
    { "src": "/api/test", "dest": "/api/test.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/analyzer", "dest": "/public/analyzer.html" },
    { "src": "/swing-detective", "dest": "/public/swing-detective.html" },
    { "src": "/lie-whisperer", "dest": "/public/lie-whisperer.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
